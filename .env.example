PORT=3100

# Database
DATABASE_URL=postgresql://postgres:your_password@localhost:5432/sanchayam

# JWT
JWT_SECRET=change_this_to_a_long_random_string_at_least_32_chars

# Encryption key for API keys stored in the database (64 hex chars = 32 bytes)
# Generate with: openssl rand -hex 32
ENCRYPTION_KEY=change_this_to_64_hex_chars

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5173

NODE_ENV=development

# SMTP - required for OTP and invite emails
SMTP_HOST=smtp.yourprovider.com
SMTP_PORT=587
SMTP_USER=your_smtp_user
SMTP_PASS=your_smtp_password
SMTP_FROM=noreply@yourdomain.com

# Twelve Data API key - required for market price feeds
# Get one at https://twelvedata.com
TWELVE_DATA_API_KEY=your_twelve_data_api_key

# DeepSeek API key - optional, used for corporate action extraction (NSE name changes, mergers)
DEEPSEEK_API_KEY=your_deepseek_api_key

# Bad email validator URL - optional, used to block disposable/invalid email addresses
# If not set, all emails are accepted
BAD_EMAIL_VALIDATOR_URL=
